{
  "family": "ventas-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::570934198047:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "570934198047.dkr.ecr.us-east-2.amazonaws.com/ventas-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:password123@ventasdb.cdgsmge4o3bp.us-east-2.rds.amazonaws.com:5432/postgres?sslmode=require"
        }
      ]
    }
  ]
}
