{
  "family": "ventas-app-pagos-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "app-pagos",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/ventas-app-pagos:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8002,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "MP_ACCESS_TOKEN",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/ventas/MP_ACCESS_TOKEN"
        },
        {
          "name": "MP_PUBLIC_KEY",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/ventas/MP_PUBLIC_KEY"
        }
      ]
    }
  ]
}
