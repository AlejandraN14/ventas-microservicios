{
  "family": "ventas-app-pagos-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::570934198047:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "app-pagos",
      "image": "570934198047.dkr.ecr.us-east-2.amazonaws.com/ventas-app-pagos:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8002,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "MP_ACCESS_TOKEN",
          "valueFrom": "arn:aws:ssm:us-east-2:570934198047:parameter/ventas/MP_ACCESS_TOKEN"
        },
        {
          "name": "MP_PUBLIC_KEY",
          "valueFrom": "arn:aws:ssm:us-east-2:570934198047:parameter/ventas/MP_PUBLIC_KEY"
        }
      ]
    }
  ]
}
